<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.GiamDinhNative" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Theme khởi động: hiện logo qua Splash Screen API (Android 12+), tự fallback đẹp trên bản cũ -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/logo_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_logo_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.GiamDinhNative</item>
    </style>
</resources>
